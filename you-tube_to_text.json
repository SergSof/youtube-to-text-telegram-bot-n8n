    {
      "parameters": {
        "jsCode": "// data – base64-строка из \"Extract from File\"\nconst base64 = $json.data || '';\nlet raw = Buffer.from(base64, 'base64').toString('utf8');\nraw = raw.replace(/\\r/g, '');\n\n// 1) Убираем VTT-заголовки и таймкоды целыми строками\nconst lines = raw.split('\\n');\n\nconst cleanedLines = [];\nfor (let line of lines) {\n  line = line.trim();\n  if (!line) continue;\n\n  // заголовки\n  if (line === 'WEBVTT') continue;\n  if (line.startsWith('Kind:')) continue;\n  if (line.startsWith('Language:')) continue;\n\n  // таймкоды вида \"00:00:03.199 --> 00:00:05.229 align:start position:0%\"\n  if (/^\\d{2}:\\d{2}:\\d{2}\\.\\d{3}\\s+-->\\s+\\d{2}:\\d{2}:\\d{2}\\.\\d{3}/.test(line)) continue;\n\n  // иногда в твоём тексте проскакивает \"\\n\" как литерал\n  if (line === '\\\\n' || line === '\\\\') continue;\n\n  cleanedLines.push(line);\n}\n\n// 2) В одной строке могут быть inline таймкоды и <c>…</c>.\n//    Превращаем всё в нормальный текст.\nlet textLines = cleanedLines.map((line) => {\n  let s = line;\n\n  // убрать <00:00:00.719> и любые <...> теги (включая <c>, </c>)\n  s = s.replace(/<[^>]+>/g, ' ');\n\n  // нормализуем пробелы\n  s = s.replace(/\\s+/g, ' ').trim();\n\n  // убрать служебные вставки в квадратных скобках\n  // (можешь расширить список)\n  s = s.replace(/\\[(музыка|аплодисменты|смех|шум|вздох)\\]/gi, '').trim();\n\n  // убрать оставшиеся \"пустые\" строки\n  return s;\n}).filter(Boolean);\n\n// 3) Убираем повторы: подряд и в небольшом окне (например последние 6 строк)\nconst out = [];\nconst window = [];            // храним нормализованные строки\nconst WINDOW_SIZE = 6;\n\nconst norm = (s) =>\n  s.toLowerCase()\n   .replace(/[«»\"“”]/g, '\"')\n   .replace(/[^\\p{L}\\p{N}\\s.,!?-]/gu, '')  // выкинуть странные символы, оставить буквы/цифры/пунктуацию\n   .replace(/\\s+/g, ' ')\n   .trim();\n\nfor (const s of textLines) {\n  const n = norm(s);\n  if (!n) continue;\n\n  // 3.1) убрать подряд идущий дубль\n  if (out.length > 0 && norm(out[out.length - 1]) === n) continue;\n\n  // 3.2) убрать повтор в маленьком окне (YouTube часто дублирует одну фразу 2-3 раза подряд)\n  if (window.includes(n)) continue;\n\n  out.push(s);\n\n  window.push(n);\n  if (window.length > WINDOW_SIZE) window.shift();\n}\n\n// 4) Склеиваем в один текст\nlet text = out.join(' ');\n\n// финальная нормализация пробелов\ntext = text.replace(/\\s+/g, ' ').trim();\n\nreturn [{\n  ...$json,\n  text,\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
