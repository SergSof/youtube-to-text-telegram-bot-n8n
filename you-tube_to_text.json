        "jsCode": "const text = $json.message?.text?.trim() || '';\nconst chatId = $json.message?.chat?.id ?? $json.chat?.id ?? null;\n\nconst ytRegex = /^(https?:\\/\\/)?(www\\.)?(youtube\\.com|youtu\\.be)\\//i;\n\nif (!text) {\n  return [{\n    is_valid: false,\n    reason: 'empty',\n    chat_id: chatId,\n  }];\n}\n\nif (!ytRegex.test(text)) {\n  return [{\n    is_valid: false,\n    url: text,\n    reason: 'not_youtube',\n    chat_id: chatId,\n  }];\n}\n\nreturn [{\n  is_valid: true,\n  url: text,\n  chat_id: chatId,\n}];\n"
      },
